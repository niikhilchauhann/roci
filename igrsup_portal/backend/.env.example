BHUNAKSHA_MAX_RETRIES=3
BHUNAKSHA_REQUEST_SLEEP_SECONDS=0.5
BHULEKH_BASE_URL=https://example-bhulekh.local
BHULEKH_TIMEOUT_SECONDS=45
