APP_NAME=ROCI Ayodhya Engine
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000"]

AYODHYA_CENTER_LAT=26.7999
AYODHYA_CENTER_LNG=82.2042
AYODHYA_RADIUS_KM=40
AYODHYA_MIN_LAT=26.60
AYODHYA_MAX_LAT=27.00
AYODHYA_MIN_LNG=81.95
AYODHYA_MAX_LNG=82.45

BHUNAKSHA_WFS_URL=https://example-bhunaksha.local/geoserver/ows
BHUNAKSHA_LAYER_NAME=ayodhya:land_parcels
